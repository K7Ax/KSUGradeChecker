# ===== KSU Grade Checker — settings =====
# Fill in the 3 values below, save this file, then run:  npm start
# This file stays on your PC only. Your credentials are sent ONLY to edugate's
# official login page — never to anyone else.

# 1) Your Telegram bot token from @BotFather
BOT_TOKEN=

# 2) Your edugate login (used only to sign in at edugate)
EDUGATE_USERNAME=
EDUGATE_PASSWORD=


# ---------- Advanced (you can ignore everything below) ----------

# Leave CHAT_ID blank: the bot links to you automatically the first time you
# send /start to it on Telegram. Only set this if you want to fix it manually.
CHAT_ID=

# How often to check edugate, in milliseconds (default 10 minutes).
POLL_MS=600000

# Direct URL to the course-results page (same for all KSU students).
RESULTS_URL=https://edugate.ksu.edu.sa/ksu/ui/student/courses_results/index/forwardCoursesResults.faces
