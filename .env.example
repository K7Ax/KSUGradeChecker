# ===== KSU Grade Checker — example config =====
# Copy this file to ".env" and fill in your own values.
# IMPORTANT: ".env" is git-ignored and must NEVER be committed or shared.
# Your data stays on your PC. Credentials below are sent ONLY to edugate's
# official login page — never to any third party.

# Telegram bot token from @BotFather (e.g. 123456:ABC-DEF...)
BOT_TOKEN=

# Your numeric Telegram chat id.
# Run `npm start`, send /start to your bot, and it replies with your chat id.
CHAT_ID=

# How often to check edugate, in milliseconds (default 10 minutes).
POLL_MS=600000

# edugate credentials for automatic re-login (this account type has no 2FA).
# Used ONLY to sign in at edugate. Leave blank to log in manually via `npm run login`.
EDUGATE_USERNAME=
EDUGATE_PASSWORD=

# Direct URL to the course-results page (same for all KSU students).
RESULTS_URL=https://edugate.ksu.edu.sa/ksu/ui/student/courses_results/index/forwardCoursesResults.faces
